# ============================================================
# 黑暗森林 - Docker 构建忽略文件
# ============================================================

# 排除 Git 目录
.git/
.gitignore

# 排除 Node.js 依赖
node_modules/
npm-debug.log
yarn-error.log

# 排除 Go 构建产物
bin/
*.exe
*.dll

# 排除 Docker 相关
docker-compose*.yml
Dockerfile*
.dockerignore

# 排除配置文件
.env
.env.*
.env.example

# 排除日志
logs/
*.log

# 排除文档
docs/
*.md
README.md

# 排除备份和临时文件
backups/
tmp/
temp/
*.bak
*.tmp

# 排除 Prisma
prisma/

# 排除 nanobot（可选模块）
nanobot/

# 排除前端构建产物（保留 dist 用于 Docker 构建）
# frontend/dist/

# 排除 macOS 和 Windows 系统文件
.DS_Store
Thumbs.db

# 排除 Next.js 构建产物
.next/
.build/