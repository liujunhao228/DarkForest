# ============================================================
# Docker 忽略文件 - 优化：排除不必要内容，加速构建
# ============================================================

# ---- 依赖和构建缓存 ----
node_modules
.next
out
dist

# ---- 包管理器锁文件（保留 bun.lockb 用于构建缓存）----
package-lock.json
yarn.lock
pnpm-lock.yaml

# ---- 环境变量和密钥 ----
.env
.env.*
!.env.example
*.pem
*.key

# ---- 数据库文件（运行时生成，不应从构建上下文复制）----
*.db
*.db-journal

# ---- Git ----
.git
.gitignore
.gitattributes

# ---- IDE 和编辑器 ----
.vscode
.idea
*.swp
*.swo
*~
.DS_Store

# ---- 日志 ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---- 测试和覆盖率 ----
coverage
.nyc_output
test-results
playwright-report
e2e/

# ---- 文档（Docker 构建不需要）----
README.md
AUTHORITATIVE-SERVER-IMPLEMENTATION.md
BROADCAST-FLOW-IMPLEMENTATION.md
DEPLOYMENT.md
MATCHMAKING-INTEGRATION.md
ONLINE-MODE.md
API-README.md
LICENSE
*.md

# ---- 项目特定目录 ----
.qwen/
.zscripts/
mini-services/
examples/
backups/
temp/
tmp/

# ---- CI/CD ----
.github/
.gitlab-ci.yml
Jenkinsfile
