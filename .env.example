# ============================================================
# 黑暗森林 (Dark Forest) - 环境变量示例 (生产环境)
# 复制为 .env 并填入实际值
# cp .env.example .env
# 
# ⚠️ 注意: 永远不要将 .env 文件提交到 Git!
# ============================================================

# -------------------- 数据库配置 --------------------
# SQLite 数据库路径 (Docker 容器内路径)
DATABASE_URL=file:/app/db/custom.db

# Prisma 日志级别: error | warn | info | query
PRISMA_LOG_LEVEL=error

# -------------------- WebSocket 配置 --------------------
# WebSocket 服务器端口
NEXT_PUBLIC_WEBSOCKET_PORT=3003
WEBSOCKET_PORT=3003

# -------------------- 认证配置 --------------------
# JWT 密钥 (生产环境必须修改为强随机字符串)
# 生成方法: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# 管理员密钥 (用于管理员 API 认证)
# 生成方法: openssl rand -base64 32
ADMIN_SECRET_KEY=your-admin-secret-key-change-in-production

# -------------------- 可选配置 --------------------
# Next.js 公共 URL (用于回调等)
# NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Node 环境 (由 Docker Compose 自动设置)
# NODE_ENV=production
