# 黑暗森林 — 全局环境变量示例(聚合参考)
# 复制为 .env 后按需修改。本文件为参考文档,不会被任何服务自动加载;
# 各服务实际加载方式见下方说明。

# 加载方式:
# - frontend: Vite 自动读取 frontend/.env(本文件中的 VITE_ 变量需复制到 frontend/.env)
# - backend:  不自动加载 .env,需通过 shell export、docker-compose env_file 或 systemd EnvironmentFile 注入
# - mcpserver: 同 backend,需通过外部机制注入(也支持运行时通过 admin API 修改部分项)

# ============================================================
# Frontend(仅 VITE_ 前缀变量会暴露给前端代码)
# ============================================================

# 后端 HTTP API 基址(留空则使用同源相对路径)
VITE_API_URL=http://localhost:8080
# 后端 WebSocket 地址(留空则回退到同源 /ws)
VITE_WS_URL=ws://localhost:8080/ws


# ============================================================
# Backend(Go 后端服务)
# ============================================================

# === Database (PostgreSQL) ===
# 格式: postgres://user:password@host:port/database?sslmode=disable
DATABASE_URL=postgres://darkforest:darkforest_secret@localhost:5432/darkforest?sslmode=disable

# === 迁移 ===
# golang-migrate 迁移文件目录(相对路径相对于 backend/ 工作目录)
MIGRATIONS_DIR=./internal/db/migrations

# === 密钥(生产环境必须修改) ===
# JWT 签名密钥
JWT_SECRET=your_jwt_secret_here
# 管理员初始化密钥
ADMIN_SECRET_KEY=your_admin_secret_here

# === Server ===
# HTTP 监听端口
PORT=8080
# 运行环境: development | production
ENVIRONMENT=development
# CORS 允许的来源,逗号分隔;留空则在开发模式下允许所有来源(*)
# 示例: https://app.example.com,https://admin.example.com
CORS_ALLOW_ORIGINS=

# === 静态资源 ===
# 前端构建产物目录(由后端作为静态资源服务)
STATIC_DIR=./frontend/dist


# ============================================================
# MCP Server(Agent 接入服务)
# ============================================================

# === 游戏后端连接 ===
# 游戏后端 HTTP API 地址
# 注意:可通过 PUT /admin/game-server 运行时修改并持久化到 SQLite(优先级高于此环境变量)
GAME_API_URL=http://localhost:8080
# 游戏后端 WebSocket 地址
# 注意:可通过 PUT /admin/game-server 运行时修改并持久化到 SQLite(优先级高于此环境变量)
GAME_WS_URL=ws://localhost:8080/ws
# MCP Server 监听端口
MCP_PORT=9090
# Streamable HTTP 端点路径
MCP_ENDPOINT=/mcp
# SQLite 数据库文件路径
DB_PATH=./data/mcpserver.db
# 游戏后端 admin JWT(用于预注册账户时生成邀请码)
ADMIN_TOKEN=

# === 游戏服务器连接稳定性 ===
# Agent 会话空闲超时(秒);超过则归还账户到池(双层超时之一:游戏会话层)
SESSION_IDLE_TIMEOUT=300
# WS 快速重连阶段次数;超过后进入慢速无限重试
WS_RECONNECT_MAX=5
# WS pong 等待超时(秒);超过则主动断开触发重连
WS_HEARTBEAT_TIMEOUT=10
# WS 慢速阶段重连退避上限秒数(默认 5min)
WS_RECONNECT_MAX_BACKOFF=300
# WS 离线发送队列上限(条数);满时丢弃最旧
WS_OFFLINE_QUEUE_MAX=1000

# === HTTP 客户端稳定性 ===
# HTTP 请求最大重试次数(网络错误与 5xx)
HTTP_RETRY_MAX=3
# HTTP 熔断阈值(连续失败次数);仅作用于需要 token 的请求
HTTP_CIRCUIT_BREAKER_THRESHOLD=10
# HTTP 熔断冷却秒数
HTTP_CIRCUIT_BREAKER_COOLDOWN=30

# === MCP 会话稳定性 ===
# MCP SDK session 空闲超时秒数(双层超时之一:SDK 层);0 表示不超时
MCP_SESSION_TIMEOUT=1800
