# 后端环境变量示例
# 复制为 .env 后按需修改;所有变量均有默认值,生产环境务必覆盖带密钥的项

# === Database (PostgreSQL) ===
# 格式: postgres://user:password@host:port/database?sslmode=disable
DATABASE_URL=postgres://darkforest:darkforest_secret@localhost:5432/darkforest?sslmode=disable

# === 迁移 ===
# golang-migrate 迁移文件目录(相对路径相对于 backend/ 工作目录)
MIGRATIONS_DIR=./internal/db/migrations

# === 密钥(生产环境必须修改) ===
# JWT 签名密钥
JWT_SECRET=your_jwt_secret_here
# 管理员初始化密钥
ADMIN_SECRET_KEY=your_admin_secret_here

# === Server ===
# HTTP 监听端口
PORT=8080
# 运行环境: development | production
ENVIRONMENT=development
# CORS 允许的来源,逗号分隔;留空则在开发模式下允许所有来源(*)
# 示例: https://app.example.com,https://admin.example.com
CORS_ALLOW_ORIGINS=

# === 静态资源 ===
# 前端构建产物目录(由后端作为静态资源服务)
STATIC_DIR=./frontend/dist
