// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================
// 用户与玩家系统
// ============================

// 预留模型 (未来账号系统)
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String?  // 预留密码字段（未来可实现账号系统）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 预留字段
  Post      Post[]
}

model Player {
  id              String   @id @default(cuid())
  userId          String   @unique  // 客户端生成的临时用户 ID（不关联 User 表）
  displayName     String   // 游戏内显示的名称
  role            String   @default("player")  // "admin" | "player"
  password        String?  // bcrypt 哈希密码（null 表示未注册，仍为临时玩家）
  avatar          Int      @default(0)  // 头像 ID
  wins            Int      @default(0)
  losses          Int      @default(0)
  draws           Int      @default(0)
  totalMatches    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // 对局记录
  matchPlayers    MatchPlayer[]

  // 当前匹配队列
  matchmakingQueue MatchmakingQueue?

  // 创建的邀请码
  createdInvitations InvitationCode[] @relation("CreatedInvitations")

  // 使用过的邀请码
  usedInvitations InvitationCode[] @relation("UsedInvitations")

  // 创建的自定义匹配队列
  createdCustomQueues CustomMatchQueue[]

  // 加入的自定义匹配队列
  customMatchQueues  CustomMatchQueuePlayer[]
}

// ============================
// 邀请码系统
// ============================

model InvitationCode {
  id        String   @id @default(cuid())
  code      String   @unique  // 邀请码 (6 位大写字母数字)
  createdBy String   // 创建者玩家 ID
  creator   Player   @relation("CreatedInvitations", fields: [createdBy], references: [id], onDelete: Cascade)
  isUsed    Boolean  @default(false)
  usedBy    String?  // 使用者玩家 ID
  user      Player?  @relation("UsedInvitations", fields: [usedBy], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  usedAt    DateTime?
}

// ============================
// 匹配系统
// ============================

model MatchmakingQueue {
  id              String   @id @default(cuid())
  playerId        String   @unique
  player          Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  preferredCount  Int      @default(4)  // 期望玩家数 (3-5)
  joinedAt        DateTime @default(now())
  timeout         Int      @default(30000)  // 匹配超时 (ms)
}

// 自定义匹配队列（允许玩家创建并邀请其他人加入）
model CustomMatchQueue {
  id              String   @id @default(cuid())
  queueId         String   @unique  // 队列唯一标识符
  queueName       String   // 队列名称
  creatorId       String   // 创建者玩家 ID
  creator         Player   @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  maxPlayers      Int      @default(4)  // 最大玩家数 (3-5)
  minPlayers      Int      @default(3)  // 最小玩家数 (3-5)
  status          String   @default("waiting")  // waiting, matching, full, started
  players         CustomMatchQueuePlayer[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// 自定义匹配队列中的玩家
model CustomMatchQueuePlayer {
  id              String   @id @default(cuid())
  queueId         String
  queue           CustomMatchQueue @relation(fields: [queueId], references: [queueId], onDelete: Cascade)
  playerId        String
  player          Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  joinedAt        DateTime @default(now())
  isReady         Boolean  @default(false)

  @@unique([queueId, playerId])
}

// ============================
// 对局系统
// ============================

model Match {
  id              String   @id @default(cuid())
  roomCode        String   @unique  // 房间号 (6 位字母数字)
  hostId          String   // 房主玩家 ID
  status          String   @default("waiting")  // waiting, playing, finished
  playerCount     Int      @default(4)
  aiCount         Int      @default(0)
  winnerId        String?  // 胜利者 ID
  winnerType      String?  // "human" 或 "ai"
  totalTurns      Int      @default(0)  // 总回合数
  duration        Int      @default(0)  // 对局时长 (秒)
  startedAt       DateTime?
  finishedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // 参与的玩家
  players         MatchPlayer[]

  // 对局日志 (JSON 格式存储关键事件)
  gameLog         String?  // JSON 数组
}

model MatchPlayer {
  id              String   @id @default(cuid())
  matchId         String
  match           Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  playerId        String
  player          Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  playerNumber    Int      // 玩家编号 (0-4)
  isHost          Boolean  @default(false)
  position        Int      // 初始星系位置
  finalRank       Int?     // 最终排名
  isEliminated    Boolean  @default(false)
  eliminatedTurn  Int?     // 被淘汰的回合
  energy          Int      @default(3)  // 初始能量
  destroyedStars  Int      @default(0)  // 摧毁的恒星数
  broadcastCount  Int      @default(0)  // 成功广播次数
  strikeCount     Int      @default(0)  // 成功打击次数
  createdAt       DateTime @default(now())

  @@unique([matchId, playerId])
  @@unique([matchId, playerNumber])
}

// ============================
// 预留模型 (未来扩展)
// ============================

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}