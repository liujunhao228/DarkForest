# 游戏后端 HTTP API 地址
GAME_API_URL=http://localhost:8080
# 游戏后端 WebSocket 地址
GAME_WS_URL=ws://localhost:8080/ws
# MCP Server 监听端口
MCP_PORT=9090
# Streamable HTTP 端点路径
MCP_ENDPOINT=/mcp
# SQLite 数据库文件路径
DB_PATH=./data/mcpserver.db
# 游戏后端 admin JWT(用于预注册账户时生成邀请码)
ADMIN_TOKEN=
# Agent 会话空闲超时(秒),超时归还账户
SESSION_IDLE_TIMEOUT=300
# WS 重连最大次数
WS_RECONNECT_MAX=5
