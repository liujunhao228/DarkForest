# MCP Server 环境变量示例
# 复制为 .env 后按需修改;所有变量均有默认值

# === 游戏后端连接 ===
# 游戏后端 HTTP API 地址
# 注意:可通过 PUT /admin/game-server 运行时修改并持久化到 SQLite(优先级高于此环境变量)
GAME_API_URL=http://localhost:8080
# 游戏后端 WebSocket 地址
# 注意:可通过 PUT /admin/game-server 运行时修改并持久化到 SQLite(优先级高于此环境变量)
GAME_WS_URL=ws://localhost:8080/ws
# MCP Server 监听端口
MCP_PORT=9090
# Streamable HTTP 端点路径
MCP_ENDPOINT=/mcp
# SQLite 数据库文件路径
DB_PATH=./data/mcpserver.db
# 游戏后端 admin JWT(用于预注册账户时生成邀请码)
ADMIN_TOKEN=

# === 游戏服务器连接稳定性 ===
# Agent 会话空闲超时(秒);超过则归还账户到池(双层超时之一:游戏会话层)
SESSION_IDLE_TIMEOUT=600
# WS 快速重连阶段次数;超过后进入慢速无限重试
WS_RECONNECT_MAX=5
# WS pong 等待超时(秒);超过则主动断开触发重连
WS_HEARTBEAT_TIMEOUT=10
# WS 慢速阶段重连退避上限秒数(默认 5min)
WS_RECONNECT_MAX_BACKOFF=300
# WS 离线发送队列上限(条数);满时丢弃最旧
WS_OFFLINE_QUEUE_MAX=1000

# === HTTP 客户端稳定性 ===
# HTTP 请求最大重试次数(网络错误与 5xx)
HTTP_RETRY_MAX=3
# HTTP 熔断阈值(连续失败次数);仅作用于需要 token 的请求
HTTP_CIRCUIT_BREAKER_THRESHOLD=10
# HTTP 熔断冷却秒数
HTTP_CIRCUIT_BREAKER_COOLDOWN=30

# === MCP 会话稳定性 ===
# MCP SDK session 空闲超时秒数(双层超时之一:SDK 层);0 表示不超时
MCP_SESSION_TIMEOUT=1800
