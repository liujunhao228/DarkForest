# 黑暗森林 AI Agent 配置模板
# 复制为 .env 并填入你的配置

# REST API 服务器地址（认证、匹配等 HTTP 接口）
API_SERVER_URL=http://localhost:3000

# WebSocket 游戏服务器地址（实时游戏通信）
GAME_SERVER_URL=http://localhost:3003

# JWT Token（用于WebSocket认证）
JWT_TOKEN=

# LLM 配置
LLM_BASE_URL=http://127.0.0.1:8900/v1
LLM_API_KEY=dummy
LLM_MODEL=
SESSION_ID=darkforest-ai

# AI 玩家名称
AI_PLAYER_NAME=AI-文明
